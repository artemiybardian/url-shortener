# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Databases
AUTH_DB_NAME=auth_db
SHORTENER_DB_NAME=shortener_db
ANALYTICS_DB_NAME=analytics_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=super-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Services (internal Docker network)
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=8001
SHORTENER_SERVICE_HOST=shortener-service
SHORTENER_SERVICE_PORT=8002
SHORTENER_GRPC_PORT=50051
REDIRECT_SERVICE_HOST=redirect-service
REDIRECT_SERVICE_PORT=8003
ANALYTICS_SERVICE_HOST=analytics-service
ANALYTICS_SERVICE_PORT=8004
ANALYTICS_GRPC_PORT=50052
